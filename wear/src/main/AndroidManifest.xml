<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_HEALTH" />

    <!-- Für klassische Body-Sensor-Nutzung -->
    <uses-permission android:name="android.permission.BODY_SENSORS" />

    <!-- Für Android 16 / neuere Health-Granular-Permissions -->
    <uses-permission android:name="android.permission.health.READ_HEART_RATE" />

    <!-- Wichtig für Background-Zugriff auf Heart Rate bei Android 13-15 -->
    <uses-permission android:name="android.permission.BODY_SENSORS_BACKGROUND" />

    <application
        android:allowBackup="true"
        android:label="Meditation Bio Wear"
        android:supportsRtl="true"
        android:theme="@style/Theme.MeditationBio">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".WearStreamingService"
            android:exported="false"
            android:foregroundServiceType="dataSync|health" />
    </application>
</manifest>